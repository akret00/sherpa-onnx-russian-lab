@echo off
chcp 65001 >nul 2>&1
setlocal enabledelayedexpansion

:: ============================================================
:: run_asr.bat
:: Запуск распознавания речи через перетаскивание аудиофайла
:: ============================================================
:: Использование:
::   1. Создайте ярлык этого файла на рабочем столе
::   2. Перетащите аудиофайл на ярлык
::   3. Результат появится в консоли и сохранится в папку results\
:: ============================================================

title Распознавание речи

:: ----------------------------------------------------------
:: Проверка: передан ли аргумент (файл)
:: ----------------------------------------------------------
if "%~1"=="" (
    echo ============================================================
    echo   Распознавание речи
    echo ============================================================
    echo.
    echo Этот скрипт запускается перетаскиванием аудиофайла на ярлык.
    echo.
    echo Инструкция:
    echo   1. Найдите аудиофайл в проводнике
    echo   2. Перетащите его на ярлык "Распознать аудио"
    echo   3. Дождитесь завершения распознавания
    echo.
    echo Поддерживаемые форматы:
    echo   MP3, WAV, FLAC, OGG, M4A, AAC, WMA, OPUS
    echo   ^(все форматы, которые понимает ffmpeg^)
    echo.
    echo Результат будет показан в этом окне и сохранён в файл .txt
    echo.
    echo Нажмите любую клавишу для выхода...
    pause >nul
    exit /b 1
)

:: ----------------------------------------------------------
:: Получаем полный путь к перетащенному файлу
:: ----------------------------------------------------------
set "INPUT_FILE=%~1"

:: Убираем возможные лишние кавычки (на случай двойного квотинга)
set "INPUT_FILE=%INPUT_FILE:"=%"

:: ----------------------------------------------------------
:: Проверка существования файла
:: ----------------------------------------------------------
if not exist "%INPUT_FILE%" (
    echo ============================================================
    echo   Ошибка: файл не найден
    echo ============================================================
    echo.
    echo Указанный файл не существует:
    echo   %INPUT_FILE%
    echo.
    echo Возможные причины:
    echo   - Файл был перемещён или удалён
    echo   - Ярлык указывает на сетевой диск, который сейчас недоступен
    echo   - Имя файла содержит очень специальные символы
    echo.
    echo Нажмите любую клавишу для выхода...
    pause >nul
    exit /b 2
)

:: ----------------------------------------------------------
:: Определяем пути
:: ----------------------------------------------------------
:: Папка, где лежит этот bat-файл (корень проекта)
set "PROJECT_DIR=%~dp0"
set "PROJECT_DIR=%PROJECT_DIR:~0,-1%"

:: Исполняемые файлы
set "PYTHON_EXE=%PROJECT_DIR%\bin\python\python.exe"
set "ASR_SCRIPT=%PROJECT_DIR%\src\asr_vad.py"
set "MANAGE_SCRIPT=%PROJECT_DIR%\src\manage_speakers.py"

:: Папка для результатов
set "OUTPUT_DIR=%PROJECT_DIR%\results"

:: ----------------------------------------------------------
:: Проверка наличия Python и скрипта распознавания
:: ----------------------------------------------------------
if not exist "%PYTHON_EXE%" (
    echo ============================================================
    echo   Ошибка: Python не найден
    echo ============================================================
    echo.
    echo Исполняемый файл Python отсутствует:
    echo   %PYTHON_EXE%
    echo.
    echo Возможно, установка не была завершена.
    echo Запустите "Обновить распознавалку" для установки окружения.
    echo.
    echo Нажмите любую клавишу для выхода...
    pause >nul
    exit /b 3
)

if not exist "%ASR_SCRIPT%" (
    echo ============================================================
    echo   Ошибка: скрипт распознавания не найден
    echo ============================================================
    echo.
    echo Файл скрипта отсутствует:
    echo   %ASR_SCRIPT%
    echo.
    echo Возможно, установка не была завершена.
    echo Запустите "Обновить распознавалку" для обновления файлов.
    echo.
    echo Нажмите любую клавишу для выхода...
    pause >nul
    exit /b 4
)

:: ----------------------------------------------------------
:: Запуск распознавания
:: ----------------------------------------------------------
echo ============================================================
echo   Распознавание речи
echo ============================================================
echo.
echo Входной файл: %INPUT_FILE%
echo.

:: Запускаем Python-скрипт
if "%~1"=="" (
    echo Запуск менеджера спикеров...
    "%PYTHON_EXE%" "%MANAGER_SCRIPT%"
) else (
    echo Обработка файла: %~nx1...
    :: Кавычки вокруг путей обязательны для поддержки пробелов и кириллицы
    "%PYTHON_EXE%" "%ASR_SCRIPT%" --input "%INPUT_FILE%" --output-dir "%OUTPUT_DIR%" --no-timestamps
)

:: Сохраняем код возврата Python-скрипта
set "EXIT_CODE=%errorlevel%"

:: ----------------------------------------------------------
:: Вывод результата
:: ----------------------------------------------------------
echo.
echo ============================================================

if %EXIT_CODE% equ 0 (
    echo.
    echo Распознавание успешно завершено.
    echo.
    echo Текст распознавания показан выше в этом окне.
    echo Файл результата сохранён в папку:
    echo   %OUTPUT_DIR%
    echo.
    echo Вы можете:
    echo   - Скопировать текст прямо из этого окна ^(Ctrl+A, Ctrl+C^)
    echo   - Открыть сохранённый .txt файл в папке results
    echo.
) else (
    echo.
    echo Распознавание завершилось с ошибкой ^(код: %EXIT_CODE%^).
    echo.
    echo Проверьте сообщения выше в этом окне.
    echo Возможные причины:
    echo   - Формат аудиофайла не поддерживается
    echo   - Файл повреждён или имеет нулевой размер
    echo   - Недостаточно оперативной памяти
    echo   - Модели распознавания отсутствуют или повреждены
    echo.
    echo Попробуйте:
    echo   - Конвертировать файл в WAV или MP3
    echo   - Запустить "Обновить распознавалку" для проверки моделей
    echo.
)

echo Нажмите любую клавишу для выхода...
pause >nul
exit /b %EXIT_CODE%
