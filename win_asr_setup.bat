@echo off
chcp 65001 >nul 2>&1
setlocal enabledelayedexpansion

:: ============================================================
:: win_asr_setup.bat
:: Точка входа для установки и обновления проекта
:: ============================================================
:: Этот скрипт:
::   1. Проверяет наличие PowerShell
::   2. Запускает win_asr_setup.ps1 (обновление файлов проекта)
::   3. win_asr_setup.ps1 сам вызовет win_asr_init.ps1 (установка окружения)
::   4. Проверяет код возврата и сообщает пользователю о результате
:: ============================================================

title Установка распознавания речи

echo ============================================================
echo   Установка и обновление распознавания речи
echo ============================================================
echo.

:: ----------------------------------------------------------
:: Шаг 1. Проверка наличия PowerShell
:: ----------------------------------------------------------
echo [1/2] Проверка наличия PowerShell...
where powershell >nul 2>&1
if %errorlevel% neq 0 (
    echo.
    echo [ОШИБКА] PowerShell не найден в системе.
    echo.
    echo PowerShell — обязательный компонент Windows.
    echo Если вы используете Windows 7, установите PowerShell вручную:
    echo https://docs.microsoft.com/en-us/powershell/
    echo.
    echo Нажмите любую клавишу для выхода...
    pause >nul
    exit /b 1
)
echo PowerShell найден.
echo.

:: ----------------------------------------------------------
:: Шаг 2. Проверка наличия файла win_asr_setup.ps1
:: ----------------------------------------------------------
if not exist "%~dp0win_asr_setup.ps1" (
    echo [ОШИБКА] Файл win_asr_setup.ps1 не найден в папке скрипта.
    echo Убедитесь, что вы поместили оба файла в одну папку:
    echo   - win_asr_setup.bat
    echo   - win_asr_setup.ps1
    echo.
    echo Нажмите любую клавишу для выхода...
    pause >nul
    exit /b 2
)

:: ----------------------------------------------------------
:: Шаг 3. Запуск PowerShell-скрипта обновления
:: ----------------------------------------------------------
echo [2/2] Запуск обновления и установки...
echo.
echo Пожалуйста, подождите. Это может занять несколько минут.
echo Не закрывайте это окно и окно PowerShell.
echo.
echo ============================================================

:: Запускаем PowerShell с политикой Bypass
:: -ExecutionPolicy Bypass — временно разрешает выполнение скриптов без подписи
:: -File — указывает путь к исполняемому ps1-файлу
:: %~dp0 — раскрывается в полный путь к папке, где лежит этот bat-файл
powershell -ExecutionPolicy Bypass -File "%~dp0win_asr_setup.ps1"

:: ----------------------------------------------------------
:: Шаг 4. Проверка кода возврата
:: ----------------------------------------------------------
set EXIT_CODE=%errorlevel%

echo.
echo ============================================================

if %EXIT_CODE% equ 0 (
    echo.
    echo [ГОТОВО] Установка и обновление успешно завершены!
    echo.
    echo Теперь вы можете закрыть это окно и запустить
    echo ярлык "Распознать аудио" на рабочем столе.
    echo.
) else (
    echo.
    echo [ОШИБКА] Установка прервана с ошибкой (код: %EXIT_CODE%).
    echo.
    echo Проверьте сообщения в окне PowerShell выше.
    echo Возможные причины:
    echo   - Нет подключения к интернету
    echo   - Недостаточно свободного места на диске
    echo   - Антивирус заблокировал скачивание
    echo.
    echo Вы можете запустить этот скрипт повторно — установка
    echo продолжится с того места, где остановилась.
    echo.
)

:: Ждём нажатия клавиши в любом случае, чтобы пользователь успел
:: прочитать сообщение (окно не закроется мгновенно)
echo Нажмите любую клавишу для выхода...
pause >nul
exit /b %EXIT_CODE%
